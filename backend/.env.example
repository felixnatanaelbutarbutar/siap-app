# =============================================================
# SIAP Backend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://siap_user:siap_password@localhost:5432/siap_db

# --- JWT ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=12h

# --- MinIO (File Storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=siap_minio_access
MINIO_SECRET_KEY=siap_minio_secret
MINIO_BUCKET=siap-storage

# --- Firebase Cloud Messaging (Push Notification) ---
# Letakkan file serviceAccountKey.json di dalam folder /backend
# Download dari: console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
FCM_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Alternatif: isi langsung sebagai environment variable
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- CORS ---
# Domain yang diizinkan mengakses API (pisahkan dengan koma untuk multiple)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=5

# --- Logging ---
LOG_LEVEL=debug
LOG_DIR=./logs
