# =============================================================
# SIAP Backend — Production Environment Variables
# Salin file ini menjadi .env.production dan isi nilainya
# JANGAN commit file .env ke repository!
# =============================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=siap_user
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
POSTGRES_DB=siap_db

# DATABASE_URL (digunakan oleh Prisma di dalam container)
DATABASE_URL=postgresql://siap_user:GANTI_DENGAN_PASSWORD_KUAT@postgres:5432/siap_db

# --- JWT ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_SECRET_YANG_SANGAT_PANJANG_DAN_ACAK
JWT_EXPIRES_IN=12h

# --- MinIO ---
MINIO_ACCESS_KEY=GANTI_DENGAN_ACCESS_KEY
MINIO_SECRET_KEY=GANTI_DENGAN_SECRET_KEY_MIN_8_KARAKTER
MINIO_BUCKET=siap-storage

# --- Firebase (Push Notification) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- CORS (domain production) ---
CORS_ALLOWED_ORIGINS=https://admin.siap.yourdomain.com

# --- Server ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
